<UserControl x:Class="HoroshieIgry.Games.FindColorGame.Controls.PraiseBurstOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             IsHitTestVisible="False"
             Visibility="Collapsed">

    <Grid>
        <Canvas x:Name="ParticleCanvas"/>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#CCFFFFFF"
                CornerRadius="18"
                Padding="28,16"
                BorderBrush="#2B5C9A"
                BorderThickness="3"
                x:Name="PraiseCard"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="PraiseScale" ScaleX="0.6" ScaleY="0.6"/>
            </Border.RenderTransform>
            <StackPanel HorizontalAlignment="Center">
                <kenney:KenneyImage Width="48"
                                    Height="48"
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Center"
                                    AssetPath="{x:Static ui:KenneyPaths.Star}"/>
                <TextBlock x:Name="PraiseText"
                           Text="Отлично!"
                           Style="{StaticResource KenneyDialogTitleText}"
                           FontSize="26"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
