<UserControl x:Class="HoroshieIgry.Games.PaperPlaneGame.Controls.PaperPlaneCrashOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             Visibility="Collapsed"
             IsHitTestVisible="True"
             Panel.ZIndex="8">

    <Border Background="#88000000">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FFFDF8"
                CornerRadius="18"
                Padding="28,24"
                BorderBrush="#2B5C9A"
                BorderThickness="4"
                MinWidth="360">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Попробуем ещё?"
                           Style="{StaticResource KenneyPanelTitleText}"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <kenney:KenneyButton Label="Играть снова"
                                         Width="200"
                                         Height="56"
                                         Margin="0,0,16,0"
                                         AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                         Click="RetryButton_Click"/>
                    <kenney:KenneyButton Label="В каталог"
                                         Width="180"
                                         Height="56"
                                         AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                         Click="CatalogButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
