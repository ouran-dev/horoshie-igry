<UserControl x:Class="HoroshieIgry.Games.SortingGame.SortingGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HoroshieIgry.Games.SortingGame.Controls"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Width="548" Height="72">
                <kenney:KenneyPanel Width="120"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Уровень"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LevelDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="200"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Наведи порядок"
                                   Style="{StaticResource KenneyGameStatTitleText}"/>
                        <TextBlock Text="Классификация и внимание"
                                   Style="{StaticResource KenneyGameStatSubtitleText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="120"
                                    Height="72"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Время"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ElapsedDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </StackPanel>
        </Viewbox>

        <TextBlock Grid.Row="1"
                   Text="{Binding HintText}"
                   Style="{StaticResource KenneyHintText}"
                   FontSize="22"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="16,0,16,10"/>

        <Viewbox Grid.Row="2"
                 Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="8,0">
            <controls:SortingPlayfieldControl x:Name="Playfield"
                                              LevelCompleted="Playfield_LevelCompleted"/>
        </Viewbox>

        <Viewbox Grid.Row="3"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,10,0,0"
                 Panel.ZIndex="4">
            <StackPanel Orientation="Horizontal" Width="420" Height="56">
                <kenney:KenneyButton Height="56"
                                     Width="180"
                                     Margin="0,0,16,0"
                                     Label="Домой"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                     Click="HomeButton_Click"/>
                <kenney:KenneyButton Height="56"
                                     Width="220"
                                     Label="Начать заново"
                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                     Click="RestartButton_Click"/>
            </StackPanel>
        </Viewbox>

        <controls:SortingVictoryOverlay x:Name="VictoryOverlay"
                                        Grid.RowSpan="4"
                                        Panel.ZIndex="5"
                                        IsHitTestVisible="False"/>
    </Grid>
</UserControl>
