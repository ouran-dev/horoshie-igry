<UserControl x:Class="HoroshieIgry.Games.PaperPlaneGame.PaperPlaneGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HoroshieIgry.Games.PaperPlaneGame.Controls"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Width="620" Height="72">
                <kenney:KenneyPanel Width="110"
                                    Height="72"
                                    Margin="0,0,12,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Уровень"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LevelDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="170"
                                    Height="72"
                                    Margin="0,0,12,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Птичка"
                                   Style="{StaticResource KenneyGameStatTitleText}"
                                   FontSize="18"/>
                        <TextBlock Text="Координация и внимание"
                                   Style="{StaticResource KenneyGameStatSubtitleText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="110"
                                    Height="72"
                                    Margin="0,0,12,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Звёзды"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StarsDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="110"
                                    Height="72"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Путь"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DistanceDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </StackPanel>
        </Viewbox>

        <TextBlock Grid.Row="1"
                   Text="{Binding HintText}"
                   Style="{StaticResource KenneyHintText}"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="16,0,16,8"/>

        <controls:PaperPlanePlayfieldControl x:Name="Playfield"
                                             Grid.Row="2"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             Height="450"
                                             Margin="8,0"
                                             LevelCompleted="Playfield_LevelCompleted"
                                             LevelCrashed="Playfield_LevelCrashed"
                                             ProgressChanged="Playfield_ProgressChanged"
                                             TutorialDismissed="Playfield_TutorialDismissed"/>

        <Viewbox Grid.Row="3"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,10,0,0"
                 Panel.ZIndex="4">
            <StackPanel Orientation="Horizontal" Width="420" Height="56">
                <kenney:KenneyButton Height="56"
                                     Width="180"
                                     Margin="0,0,16,0"
                                     Label="Домой"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                     Click="HomeButton_Click"/>
                <kenney:KenneyButton Height="56"
                                     Width="220"
                                     Label="Начать заново"
                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                     Click="RestartButton_Click"/>
            </StackPanel>
        </Viewbox>

        <controls:PaperPlaneTutorialOverlay x:Name="TutorialOverlay"
                                            Grid.Row="2"/>

        <controls:PaperPlaneCrashOverlay x:Name="CrashOverlay"
                                         Grid.RowSpan="4"
                                         RetryRequested="CrashOverlay_RetryRequested"
                                         CatalogRequested="CrashOverlay_CatalogRequested"/>

        <controls:PaperPlaneVictoryOverlay x:Name="VictoryOverlay"
                                           Grid.RowSpan="4"
                                           NextFlightRequested="VictoryOverlay_NextFlightRequested"/>
    </Grid>
</UserControl>
