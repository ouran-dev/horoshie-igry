<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Фирменные цвета каталога -->
    <Color x:Key="KenneyInkColor">#2B5C9A</Color>
    <Color x:Key="KenneyMutedColor">#64748B</Color>
    <Color x:Key="KenneySoftColor">#94A3B8</Color>

    <SolidColorBrush x:Key="KenneyInkBrush" Color="{StaticResource KenneyInkColor}"/>
    <SolidColorBrush x:Key="KenneyMutedBrush" Color="{StaticResource KenneyMutedColor}"/>
    <SolidColorBrush x:Key="KenneySoftBrush" Color="{StaticResource KenneySoftColor}"/>

    <Style x:Key="KenneyTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
    </Style>

    <Style x:Key="KenneySectionTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyPanelTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyDialogTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="KenneySubtitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyMutedBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="KenneyHintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyNoteText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource KenneySoftBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="KenneyStatLabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyMutedBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyStatValueText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyGameStatTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyInkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KenneyGameStatSubtitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource KenneyMutedBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
