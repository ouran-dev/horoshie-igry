<UserControl x:Class="HoroshieIgry.Games.PaperPlaneGame.Controls.PaperPlaneTutorialOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             IsHitTestVisible="False"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Stretch"
             Panel.ZIndex="6">

    <Border Background="#E6FFFFFF"
            CornerRadius="16"
            Margin="20,0,20,14"
            Padding="18,14"
            BorderBrush="#B0C8E8"
            BorderThickness="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="🐦"
                       FontFamily="Segoe UI Emoji"
                       FontSize="42"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Держи — птичка летит вверх. Отпусти — опускается."
                           Style="{StaticResource KenneyHintText}"
                           FontSize="20"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Собирай звёзды и облетай облака. Нажми на поле, чтобы начать."
                           Style="{StaticResource KenneyGameStatSubtitleText}"
                           FontSize="17"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
