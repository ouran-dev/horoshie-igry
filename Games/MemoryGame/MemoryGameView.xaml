<UserControl x:Class="HoroshieIgry.Games.MemoryGame.MemoryGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:HoroshieIgry.Games.MemoryGame.Models"
             xmlns:controls="clr-namespace:HoroshieIgry.Games.MemoryGame.Controls"
             xmlns:dialogs="clr-namespace:HoroshieIgry.Controls"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             SizeChanged="MemoryGameView_SizeChanged">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Width="548" Height="72">
                <kenney:KenneyPanel Width="140"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="14,10">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Ходы"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding MovesDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="200"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                    PanelPadding="14,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Игра на память"
                                   Style="{StaticResource KenneyGameStatTitleText}"/>
                        <TextBlock Text="{Binding LevelTitle}"
                                   Style="{StaticResource KenneyGameStatSubtitleText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="180"
                                    Height="72"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,2">
                            <kenney:KenneyImage Width="22"
                                                Height="22"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                AssetPath="{x:Static ui:KenneyPaths.Star}"/>
                            <TextBlock Text="Найдено пар"
                                       Style="{StaticResource KenneyStatLabelText}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PairsDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </StackPanel>
        </Viewbox>

        <TextBlock Grid.Row="1"
                   Text="{Binding PreviewHint}"
                   Visibility="{Binding PreviewHintVisibility}"
                   Style="{StaticResource KenneyHintText}"
                   Margin="0,0,0,8"/>

        <Viewbox Grid.Row="2"
                 Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="4,0">
            <ItemsControl x:Name="CardsPanel"
                          ItemsSource="{Binding Cards}"
                          Width="{Binding BoardWidth}"
                          Height="{Binding BoardHeight}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding GridSize}" Columns="{Binding GridSize}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:CardModel}">
                        <controls:FlipMemoryCard CardClicked="FlipMemoryCard_CardClicked"
                            Width="{Binding DataContext.CardSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Height="{Binding DataContext.CardSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Margin="{Binding DataContext.CardMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Viewbox>

        <Viewbox Grid.Row="3"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Width="436" Height="56">
                <kenney:KenneyButton Height="56"
                                     Width="220"
                                     Margin="0,0,16,0"
                                     Label="Новая игра"
                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                     Click="NewGameButton_Click"/>
                <kenney:KenneyButton Height="56"
                                     Width="200"
                                     Label="В каталог"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                     Click="BackToCatalogButton_Click"/>
            </StackPanel>
        </Viewbox>

        <dialogs:KenneyDialogOverlay x:Name="WinDialog" Grid.RowSpan="4"/>
    </Grid>
</UserControl>
