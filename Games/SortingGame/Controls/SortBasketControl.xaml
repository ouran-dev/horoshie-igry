<UserControl x:Class="HoroshieIgry.Games.SortingGame.Controls.SortBasketControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Background="Transparent"
             IsHitTestVisible="False">

    <Grid x:Name="BasketGrid"
          RenderTransformOrigin="0.5,0.85">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="BounceScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="WiggleTransform" X="0"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <Border x:Name="BasketBody"
                Background="#FFF8E8"
                BorderBrush="#3D5A80"
                BorderThickness="3"
                CornerRadius="18"
                Padding="12,10"
                MinWidth="140"
                MinHeight="118">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe UI Emoji"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource KenneyPanelTitleText}"
                           FontSize="17"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="150"/>
            </StackPanel>
        </Border>

        <Border x:Name="GlowBorder"
                BorderBrush="#66BB6A"
                BorderThickness="4"
                CornerRadius="20"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
