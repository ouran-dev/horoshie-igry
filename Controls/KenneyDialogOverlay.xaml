<UserControl x:Class="HoroshieIgry.Controls.KenneyDialogOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             Visibility="Collapsed"
             Panel.ZIndex="100">

    <Grid Background="Transparent">
        <Viewbox Stretch="Uniform"
             StretchDirection="DownOnly"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
        <kenney:KenneyPanel Width="420"
                            AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                            PanelPadding="24,20">
            <StackPanel HorizontalAlignment="Center">
                <kenney:KenneyImage Width="40"
                                    Height="40"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Center"
                                    AssetPath="{x:Static ui:KenneyPaths.Star}"/>

                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource KenneyDialogTitleText}"
                           Margin="0,0,0,6"/>

                <TextBlock Text="{Binding Message}"
                           Style="{StaticResource KenneySubtitleText}"
                           FontSize="14"
                           Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <kenney:KenneyButton Height="48"
                                         Width="210"
                                         Margin="0,0,12,0"
                                         ContentPadding="12,8"
                                         Label="{Binding YesLabel}"
                                         AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                         Click="YesButton_Click"/>
                    <kenney:KenneyButton Height="48"
                                         Width="120"
                                         ContentPadding="12,8"
                                         Label="{Binding NoLabel}"
                                         AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                         Click="NoButton_Click"/>
                </StackPanel>
            </StackPanel>
        </kenney:KenneyPanel>
    </Viewbox>
    </Grid>
</UserControl>
