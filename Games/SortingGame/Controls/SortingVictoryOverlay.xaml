<UserControl x:Class="HoroshieIgry.Games.SortingGame.Controls.SortingVictoryOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             IsHitTestVisible="False"
             Visibility="Collapsed">

    <Grid>
        <Canvas x:Name="ParticleCanvas"/>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#D9FFFFFF"
                CornerRadius="22"
                Padding="36,20"
                BorderBrush="#2B5C9A"
                BorderThickness="4"
                x:Name="VictoryCard"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="VictoryScale" ScaleX="0.6" ScaleY="0.6"/>
            </Border.RenderTransform>
            <StackPanel HorizontalAlignment="Center">
                <kenney:KenneyImage Width="56"
                                    Height="56"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Center"
                                    AssetPath="{x:Static ui:KenneyPaths.Star}"/>
                <TextBlock Text="Отлично!"
                           Style="{StaticResource KenneyPanelTitleText}"
                           FontSize="36"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
