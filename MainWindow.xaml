<Window x:Class="HoroshieIgry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HoroshieIgry.Controls"
        xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
        xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
        Title="Хорошие игры"
        Width="1280"
        Height="800"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Grid>
        <controls:GameBackground x:Name="AppBackground"/>

        <Grid Margin="20,16,20,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>

                <kenney:KenneyButton x:Name="HomeButton"
                                     Grid.Column="0"
                                     Width="56"
                                     Height="56"
                                     Visibility="Collapsed"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRoundBlue}"
                                     IconPath="{x:Static ui:KenneyPaths.ArrowBack}"
                                     Label=""
                                     ContentPadding="0"
                                     Click="HomeButton_Click"
                                     ToolTip="Каталог игр"/>

                <TextBlock x:Name="HeaderTitleText"
                           Grid.Column="1"
                           Text="Хорошие игры"
                           Style="{StaticResource KenneyTitleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <kenney:KenneyButton Grid.Column="2"
                                     Width="56"
                                     Height="56"
                                     HorizontalAlignment="Right"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRoundBlue}"
                                     IconPath="{x:Static ui:KenneyPaths.IconSettings}"
                                     Label=""
                                     ContentPadding="0"
                                     Click="SettingsButton_Click"
                                     ToolTip="Настройки"/>
            </Grid>

            <ContentControl x:Name="ContentHost" Grid.Row="1"/>
        </Grid>

        <controls:OrganizationLogo HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,20,18"/>
    </Grid>
</Window>
