<UserControl x:Class="HoroshieIgry.Controls.Kenney.KenneyButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Cursor="Hand"
             Background="Transparent"
             PreviewMouseLeftButtonDown="Root_PreviewMouseLeftButtonDown"
             TouchDown="Root_TouchDown">

    <Grid x:Name="ButtonRoot" Background="Transparent" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Image x:Name="BackgroundImage" Stretch="Fill" IsHitTestVisible="False"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="{Binding ContentPadding, ElementName=Root}"
                    IsHitTestVisible="False">
            <Image x:Name="IconImage"
                   Width="22"
                   Height="22"
                   Margin="0,0,8,0"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>
            <TextBlock x:Name="LabelText"
                       FontWeight="SemiBold"
                       FontSize="17"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Text="{Binding Label, ElementName=Root}"/>
        </StackPanel>
    </Grid>
</UserControl>
