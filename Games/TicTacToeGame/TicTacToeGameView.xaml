<UserControl x:Class="HoroshieIgry.Games.TicTacToeGame.TicTacToeGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:HoroshieIgry.Games.TicTacToeGame.Models"
             xmlns:controls="clr-namespace:HoroshieIgry.Games.TicTacToeGame.Controls"
             xmlns:praise="clr-namespace:HoroshieIgry.Games.FindColorGame.Controls"
             xmlns:dialogs="clr-namespace:HoroshieIgry.Controls"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             SizeChanged="TicTacToeGameView_SizeChanged">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <kenney:KenneyPanel Grid.RowSpan="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,4,0"
                            Width="88"
                            Height="64"
                            PanelPadding="8,6"
                            Panel.ZIndex="2"
                            Visibility="{Binding LevelBadgeVisibility}"
                            AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Уровень"
                           Style="{StaticResource KenneyStatLabelText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding LevelBadgeDisplay}"
                           Style="{StaticResource KenneyStatValueText}"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </kenney:KenneyPanel>

        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Width="548" Height="72">
                <kenney:KenneyPanel Width="150"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Счёт"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ScoreDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   FontSize="16"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="190"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                    PanelPadding="14,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Крестики-нолики"
                                   Style="{StaticResource KenneyGameStatTitleText}"/>
                        <TextBlock Text="{Binding LevelTitle}"
                                   Style="{StaticResource KenneyGameStatSubtitleText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="180"
                                    Height="72"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Соперник"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding OpponentDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   FontSize="18"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </StackPanel>
        </Viewbox>

        <Viewbox Grid.Row="1"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,12">
            <kenney:KenneyPanel Width="520"
                                Height="88"
                                AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                PanelPadding="20,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <kenney:KenneyImage Width="36"
                                        Height="36"
                                        Margin="0,0,12,0"
                                        AssetPath="{Binding HintSymbolPath}"/>
                    <TextBlock Text="{Binding HintText}"
                               Style="{StaticResource KenneyHintText}"
                               FontSize="20"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </kenney:KenneyPanel>
        </Viewbox>

        <Viewbox Grid.Row="2"
                 Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="4,0">
            <Grid x:Name="PlayAreaGrid"
                  Background="Transparent"
                  Width="{Binding BoardWidth}"
                  Height="{Binding BoardHeight}"
                  IsHitTestVisible="True"
                  PreviewMouseLeftButtonDown="PlayAreaGrid_PreviewMouseLeftButtonDown"
                  PreviewTouchDown="PlayAreaGrid_PreviewTouchDown">
                <ItemsControl x:Name="CellsPanel"
                              ItemsSource="{Binding Cells}"
                              IsHitTestVisible="False"
                              Width="{Binding BoardWidth}"
                              Height="{Binding BoardHeight}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="3" Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TicTacToeCellModel}">
                            <controls:TicTacToeCellControl
                                Width="{Binding DataContext.CellSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Height="{Binding DataContext.CellSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Margin="{Binding DataContext.CellMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>

        <Viewbox Grid.Row="3"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Width="436" Height="56">
                <kenney:KenneyButton Height="56"
                                     Width="220"
                                     Margin="0,0,16,0"
                                     Label="Новая игра"
                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                     Click="NewGameButton_Click"/>
                <kenney:KenneyButton Height="56"
                                     Width="200"
                                     Label="В каталог"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                     Click="BackToCatalogButton_Click"/>
            </StackPanel>
        </Viewbox>

        <praise:PraiseBurstOverlay x:Name="PraiseOverlay" Grid.RowSpan="4" Panel.ZIndex="3"/>
        <dialogs:KenneyDialogOverlay x:Name="GameDialog" Grid.RowSpan="4"/>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="6"
              Visibility="{Binding ModeSelectVisibility}"
              Background="#66000000">
            <Viewbox Stretch="Uniform"
                     StretchDirection="DownOnly"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <kenney:KenneyPanel Width="460"
                                    Height="300"
                                    PanelPadding="28,24"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Крестики-нолики"
                                   Style="{StaticResource KenneyPanelTitleText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Выберите режим игры"
                                   Style="{StaticResource KenneyHintText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        <kenney:KenneyButton Height="56"
                                             Width="400"
                                             Margin="0,0,0,14"
                                             Label="Против компьютера"
                                             IconPath="{x:Static ui:KenneyPaths.IconPlay}"
                                             AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                             Click="VsComputerButton_Click"/>
                        <kenney:KenneyButton Height="56"
                                             Width="400"
                                             Margin="0,0,0,14"
                                             Label="1 на 1"
                                             IconPath="{x:Static ui:KenneyPaths.IconCircle}"
                                             AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                             Click="TwoPlayerButton_Click"/>
                        <kenney:KenneyButton Height="48"
                                             Width="400"
                                             Label="В каталог"
                                             AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGrey}"
                                             Click="BackToCatalogButton_Click"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </Viewbox>
        </Grid>
    </Grid>
</UserControl>
