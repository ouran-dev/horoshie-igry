<UserControl x:Class="HoroshieIgry.Games.MemoryGame.Controls.FlipMemoryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Opacity="{Binding Opacity}"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             SizeChanged="UserControl_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="CardHitTestButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Image x:Name="ShadowImage"
               Margin="0,4,0,0"
               Opacity="0.18"
               Stretch="Fill"
               IsHitTestVisible="False"/>

        <Border x:Name="CardShell"
                RenderTransformOrigin="0.5,0.5"
                MouseEnter="CardShell_MouseEnter"
                MouseLeave="CardShell_MouseLeave">
            <Border.RenderTransform>
                <ScaleTransform x:Name="FlipScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Grid>
                <Grid x:Name="BackFace">
                    <Image x:Name="BackImage" Stretch="Fill"/>
                    <TextBlock x:Name="BackSymbol"
                               Text="?"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
                <Grid x:Name="FrontFace" Visibility="Collapsed">
                    <Image x:Name="FrontImage" Stretch="Fill"/>
                    <Border Background="{Binding FrontColor, Converter={StaticResource HexToBrush}}"
                            Opacity="0.32"
                            IsHitTestVisible="False"/>
                    <TextBlock x:Name="FrontSymbol"
                               FontFamily="Segoe UI Emoji"
                               FontSize="54"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextOptions.TextFormattingMode="Display"/>
                </Grid>
            </Grid>
        </Border>

        <Button x:Name="CardButton"
                Style="{StaticResource CardHitTestButtonStyle}"
                IsEnabled="{Binding IsClickable}"
                Click="CardButton_Click"
                PreviewMouseLeftButtonDown="CardButton_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="CardButton_PreviewMouseLeftButtonUp"
                PreviewTouchDown="CardButton_PreviewTouchDown"
                PreviewTouchUp="CardButton_PreviewTouchUp"
                MouseEnter="CardButton_MouseEnter"
                MouseLeave="CardButton_MouseLeave"/>
    </Grid>
</UserControl>
