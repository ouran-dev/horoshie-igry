<UserControl x:Class="HoroshieIgry.Games.MazeGame.MazeGameView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:controls="clr-namespace:HoroshieIgry.Games.MazeGame.Controls"

             xmlns:praise="clr-namespace:HoroshieIgry.Games.FindColorGame.Controls"

             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"

             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"

             HorizontalAlignment="Stretch"

             VerticalAlignment="Stretch"

             SizeChanged="MazeGameView_SizeChanged">



    <Grid x:Name="LayoutRoot"

          HorizontalAlignment="Stretch"

          VerticalAlignment="Stretch">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <Viewbox Grid.Row="0"

                 Stretch="Uniform"

                 StretchDirection="DownOnly"

                 HorizontalAlignment="Center"

                 Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal" Width="700" Height="72">

                <kenney:KenneyPanel Width="130"

                                    Height="72"

                                    Margin="0,0,10,0"

                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"

                                    PanelPadding="12,10">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Уровень"

                                   Style="{StaticResource KenneyStatLabelText}"

                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding LevelDisplay}"

                                   Style="{StaticResource KenneyStatValueText}"

                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </kenney:KenneyPanel>



                <kenney:KenneyPanel Width="190"

                                    Height="72"

                                    Margin="0,0,10,0"

                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"

                                    PanelPadding="12,10">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Лабиринт"

                                   Style="{StaticResource KenneyGameStatTitleText}"/>

                        <TextBlock Text="{Binding LevelTitle}"

                                   Style="{StaticResource KenneyGameStatSubtitleText}"

                                   Margin="0,2,0,0"/>

                    </StackPanel>

                </kenney:KenneyPanel>



                <kenney:KenneyPanel Width="130"

                                    Height="72"

                                    Margin="0,0,10,0"

                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"

                                    PanelPadding="12,10">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Пройдено"

                                   Style="{StaticResource KenneyStatLabelText}"

                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding CompletedDisplay}"

                                   Style="{StaticResource KenneyStatValueText}"

                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </kenney:KenneyPanel>



                <kenney:KenneyPanel Width="150"

                                    Height="72"

                                    Margin="0,0,10,0"

                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"

                                    PanelPadding="12,10">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Время"

                                   Style="{StaticResource KenneyStatLabelText}"

                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding ElapsedDisplay}"

                                   Style="{StaticResource KenneyStatValueText}"

                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </kenney:KenneyPanel>



                <kenney:KenneyPanel Width="150"

                                    Height="72"

                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"

                                    PanelPadding="12,10">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Лучшее"

                                   Style="{StaticResource KenneyStatLabelText}"

                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding BestTimeDisplay}"

                                   Style="{StaticResource KenneyStatValueText}"

                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </kenney:KenneyPanel>

            </StackPanel>

        </Viewbox>



        <Viewbox Grid.Row="1"

                 Stretch="Uniform"

                 StretchDirection="DownOnly"

                 HorizontalAlignment="Center"

                 Margin="0,0,0,10">

            <kenney:KenneyPanel Width="700"

                                Height="72"

                                AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"

                                PanelPadding="16,12">

                <TextBlock Text="{Binding HintText}"

                           Style="{StaticResource KenneyHintText}"

                           FontSize="20"

                           TextWrapping="Wrap"

                           TextAlignment="Center"

                           VerticalAlignment="Center"/>

            </kenney:KenneyPanel>

        </Viewbox>



        <Grid Grid.Row="2" Margin="8,0">

            <kenney:KenneyPanel AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"

                                PanelPadding="12,10"

                                IsHitTestVisible="False"/>

            <controls:MazeBoardControl x:Name="MazeBoard"

                                       Margin="12,10"

                                       HorizontalAlignment="Stretch"

                                       VerticalAlignment="Stretch"

                                       MazeCompleted="MazeBoard_MazeCompleted"/>

        </Grid>



        <Viewbox Grid.Row="3"

                 Stretch="Uniform"

                 StretchDirection="DownOnly"

                 HorizontalAlignment="Center"

                 Margin="0,12,0,0">

            <StackPanel Orientation="Horizontal" Width="700" Height="56">

                <kenney:KenneyButton Height="56"

                                     Width="150"

                                     Margin="0,0,10,0"

                                     Label="Домой"

                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"

                                     Click="HomeButton_Click"/>

                <kenney:KenneyButton Height="56"

                                     Width="210"

                                     Margin="0,0,10,0"

                                     Label="Заново"

                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"

                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"

                                     Click="RestartButton_Click"/>

                <kenney:KenneyButton x:Name="NextLevelButton"

                                     Height="56"

                                     Width="240"

                                     Label="Следующий уровень"

                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"

                                     Click="NextLevelButton_Click"/>

            </StackPanel>

        </Viewbox>



        <praise:PraiseBurstOverlay x:Name="PraiseOverlay" Grid.RowSpan="4" Panel.ZIndex="3"/>

    </Grid>

</UserControl>


