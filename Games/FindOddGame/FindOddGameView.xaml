<UserControl x:Class="HoroshieIgry.Games.FindOddGame.FindOddGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:HoroshieIgry.Games.FindOddGame.Models"
             xmlns:controls="clr-namespace:HoroshieIgry.Games.FindOddGame.Controls"
             xmlns:praise="clr-namespace:HoroshieIgry.Games.FindColorGame.Controls"
             xmlns:dialogs="clr-namespace:HoroshieIgry.Controls"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             SizeChanged="FindOddGameView_SizeChanged">

    <Grid x:Name="LayoutRoot"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <kenney:KenneyPanel Grid.RowSpan="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,4,0"
                            Width="88"
                            Height="64"
                            PanelPadding="8,6"
                            Panel.ZIndex="2"
                            AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Уровень"
                           Style="{StaticResource KenneyStatLabelText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding LevelBadgeDisplay}"
                           Style="{StaticResource KenneyStatValueText}"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </kenney:KenneyPanel>

        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Width="548" Height="72">
                <kenney:KenneyPanel Width="140"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="14,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Очки"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ScoreDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="200"
                                    Height="72"
                                    Margin="0,0,14,0"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                    PanelPadding="14,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Найди лишнее"
                                   Style="{StaticResource KenneyGameStatTitleText}"/>
                        <TextBlock Text="{Binding LevelTitle}"
                                   Style="{StaticResource KenneyGameStatSubtitleText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </kenney:KenneyPanel>

                <kenney:KenneyPanel Width="180"
                                    Height="72"
                                    AssetPath="{x:Static ui:KenneyPaths.PanelRectangle}"
                                    PanelPadding="12,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Время"
                                   Style="{StaticResource KenneyStatLabelText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeDisplay}"
                                   Style="{StaticResource KenneyStatValueText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </kenney:KenneyPanel>
            </StackPanel>
        </Viewbox>

        <Viewbox Grid.Row="1"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,12">
            <kenney:KenneyPanel Width="520"
                                Height="88"
                                AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                                PanelPadding="20,14">
                <TextBlock Text="{Binding HintText}"
                           Style="{StaticResource KenneyHintText}"
                           FontSize="22"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </kenney:KenneyPanel>
        </Viewbox>

        <Viewbox Grid.Row="2"
                 Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="4,0">
            <Grid x:Name="PlayAreaGrid"
                  Background="Transparent"
                  Width="{Binding BoardWidth}"
                  Height="{Binding BoardHeight}"
                  IsHitTestVisible="True"
                  PreviewMouseLeftButtonDown="PlayAreaGrid_PreviewMouseLeftButtonDown"
                  PreviewTouchDown="PlayAreaGrid_PreviewTouchDown">
                <ItemsControl x:Name="ChoicesPanel"
                              ItemsSource="{Binding Choices}"
                              IsHitTestVisible="False"
                              Opacity="{Binding BoardOpacity}"
                              Width="{Binding BoardWidth}"
                              Height="{Binding BoardHeight}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding ChoiceRows}" Columns="{Binding ChoiceColumns}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:OddItemModel}">
                            <controls:OddChoiceControl
                                Width="{Binding DataContext.ItemSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Height="{Binding DataContext.ItemSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Margin="{Binding DataContext.ItemMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>

        <Viewbox Grid.Row="3"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Width="436" Height="56">
                <kenney:KenneyButton Height="56"
                                     Width="220"
                                     Margin="0,0,16,0"
                                     Label="Заново"
                                     IconPath="{x:Static ui:KenneyPaths.IconRepeat}"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleGreen}"
                                     Click="RestartButton_Click"/>
                <kenney:KenneyButton Height="56"
                                     Width="200"
                                     Label="Домой"
                                     AssetPath="{x:Static ui:KenneyPaths.ButtonRectangleBlue}"
                                     Click="HomeButton_Click"/>
            </StackPanel>
        </Viewbox>

        <praise:PraiseBurstOverlay x:Name="PraiseOverlay" Grid.RowSpan="4" Panel.ZIndex="3"/>
        <dialogs:KenneyDialogOverlay x:Name="GameDialog" Grid.RowSpan="4"/>
    </Grid>
</UserControl>
