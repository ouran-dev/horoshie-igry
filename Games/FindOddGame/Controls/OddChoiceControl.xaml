<UserControl x:Class="HoroshieIgry.Games.FindOddGame.Controls.OddChoiceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:kenney="clr-namespace:HoroshieIgry.Controls.Kenney"
             xmlns:ui="clr-namespace:HoroshieIgry.Core.UI"
             xmlns:local="clr-namespace:HoroshieIgry.Games.FindOddGame.Controls"
             x:Name="Root"
             Background="Transparent"
             IsHitTestVisible="True"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="ShakeTransform" X="0"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <kenney:KenneyPanel AssetPath="{x:Static ui:KenneyPaths.PanelOutlineRectangle}"
                            PanelPadding="10,8"
                            IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center">
                <Viewbox Stretch="Uniform"
                         HorizontalAlignment="Center"
                         Width="{Binding IconSlotSize, RelativeSource={RelativeSource AncestorType=local:OddChoiceControl}}"
                         Height="{Binding IconSlotSize, RelativeSource={RelativeSource AncestorType=local:OddChoiceControl}}"
                         Margin="0,0,0,6">
                    <Grid Width="100" Height="100">
                        <kenney:KenneyImage AssetPath="{Binding TileAssetPath}"
                                            Stretch="Fill"
                                            IsHitTestVisible="False"/>
                        <Image Source="{Binding ObjectImage}"
                               Stretch="Uniform"
                               Margin="14"
                               IsHitTestVisible="False">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImage}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <Viewbox Stretch="Uniform" Margin="16">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImage}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <TextBlock Text="{Binding Emoji}"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="72"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextOptions.TextFormattingMode="Display"
                                       IsHitTestVisible="False"/>
                        </Viewbox>
                    </Grid>
                </Viewbox>

                <TextBlock Text="{Binding Label}"
                           Style="{StaticResource KenneyPanelTitleText}"
                           FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=local:OddChoiceControl}}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="{Binding LabelMaxWidth, RelativeSource={RelativeSource AncestorType=local:OddChoiceControl}}"
                           IsHitTestVisible="False"/>
            </StackPanel>
        </kenney:KenneyPanel>

        <Border x:Name="WrongFlash"
                Background="#55FF3B30"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
        <Border x:Name="CorrectFlash"
                Background="#5534C759"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
